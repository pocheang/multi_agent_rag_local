APP_ENV=dev
MODEL_BACKEND=ollama
REASONING_MODEL_BACKEND=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASONING_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_REASONING_MODEL=gpt-5.2

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password

CHROMA_COLLECTION=local_rag_collection
CHROMA_PERSIST_DIR=./data/chroma
DATA_DIR=./data/docs
CORPUS_STORE_PATH=./data/chunks/chunks.jsonl
PARENT_STORE_PATH=./data/chunks/parents.jsonl
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=600
CHILD_CHUNK_OVERLAP=120

TOP_K=4
MAX_CONTEXT_CHUNKS=6
VECTOR_TOP_K=6
BM25_TOP_K=6
HYBRID_RRF_K=60

ENABLE_RERANKER=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5

GRAPH_EXTRACTION_MODE=llm
GRAPH_TRIPLET_BATCH_CHARS=2200

SESSIONS_DIR=./data/sessions
UPLOADS_DIR=./data/uploads
AUTO_INGEST_ENABLED=false
AUTO_INGEST_INTERVAL_SECONDS=3
AUTO_INGEST_WATCH_DOCS=true
AUTO_INGEST_WATCH_UPLOADS=true
AUTO_INGEST_RECURSIVE=true
USERS_FILE=./data/security/users.json
AUTH_SESSIONS_FILE=./data/security/auth_sessions.json
AUTH_TOKEN_TTL_HOURS=24
APP_DB_PATH=./data/app.db
AUTH_LOGIN_MAX_FAILURES=8
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_REGISTER_MAX_ATTEMPTS=12
AUTH_REGISTER_WINDOW_SECONDS=300
UPLOAD_MAX_FILES=20
UPLOAD_MAX_FILE_BYTES=20971520
UPLOAD_MAX_TOTAL_BYTES=104857600
UPLOAD_READ_CHUNK_BYTES=1048576
